// Derived from docs/entity_model.md.
// USER ||--o{ LINK : "owns"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           BigInt   @id @default(autoincrement())
  email        String   @unique @db.VarChar(320)
  passwordHash String   @db.VarChar(200)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  links        Link[]

  @@map("users")
}

model Link {
  id             BigInt    @id @default(autoincrement())
  slug           String    @unique @db.VarChar(32)
  destinationUrl String    @db.VarChar(2048)
  ownerId        BigInt?
  owner          User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  creatorIp      String    @db.VarChar(45)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  // (creatorIp, createdAt) backs the per-IP rate-limit query (NFR-004).
  @@index([creatorIp, createdAt])
  // (ownerId, createdAt DESC) backs the dashboard listing (UC-001).
  @@index([ownerId, createdAt])
  @@map("links")
}
