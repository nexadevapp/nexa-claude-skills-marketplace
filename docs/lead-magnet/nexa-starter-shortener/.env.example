# Copy to .env for local dev. The defaults below match docker-compose.yml.
DATABASE_URL="postgresql://lnk:lnk@localhost:5433/lnk?schema=public"

# Origin used to render absolute short URLs (e.g., https://lnk.sh/abc).
# Override in production. The dev default works for `bun run dev`.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Anonymous link expiry window in days. NFR-005 mandates 30.
ANONYMOUS_LINK_TTL_DAYS=30

# Per-IP rate limit for anonymous shortening. NFR-004 mandates 20/hour.
RATE_LIMIT_PER_HOUR=20
